NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
VAPI_API_KEY=
# Free / trial Vapi numbers often cannot place international outbound calls (e.g. US line → +91).
# Use a number in your target country, upgrade Vapi, or test with a domestic mobile matching the line’s region.
VAPI_PHONE_NUMBER_ID=
GOOGLE_CALENDAR_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# whatsapp (default) or sms - use sms on Twilio trial without WhatsApp
TWILIO_MESSAGING_MODE=whatsapp
# WhatsApp sender, e.g. whatsapp:+14155238886 (sandbox) or approved Business sender
TWILIO_WHATSAPP_FROM=
# Required when TWILIO_MESSAGING_MODE=sms: your Twilio phone number in E.164 (trial number from console)
TWILIO_SMS_FROM=
ANTHROPIC_API_KEY=
SARVAM_API_KEY=
# Optional Sarvam voice controls (defaults: speaker=priya, pace=1.0)
SARVAM_SPEAKER=priya
SARVAM_PACE=1.0
# Optional per-language Sarvam overrides (examples):
# SARVAM_SPEAKER_ML_IN=pooja
# SARVAM_PACE_ML_IN=0.9
# SARVAM_SPEAKER_TA_IN=pooja
# SARVAM_PACE_TA_IN=0.92
# SARVAM_SPEAKER_HI_IN=priya
# SARVAM_PACE_HI_IN=1.0
CLINIC_NAME=Example Skin & Hair Clinic
CLINIC_CITY=Bengaluru
CLINIC_PHONE=
# Shown on the public intake confirmation screen (E.164 or readable)
NEXT_PUBLIC_CLINIC_PHONE=
# Voice coordinator display name in prompts, SMS/WhatsApp, and dashboard (fallback: our care coordinator)
AGENT_NAME=Aria
# Optional public value for browser web-call greeting in CALL_MODE=web.
NEXT_PUBLIC_AGENT_NAME=Aria
# Production: https://gloomindial.vercel.app (no trailing slash)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# `phone` (default): outbound PSTN call via Vapi number. `web`: save lead and test via in-app browser voice call.
CALL_MODE=phone
# Used when CALL_MODE=web to start browser call directly in-app.
NEXT_PUBLIC_VAPI_PUBLIC_KEY=
NEXT_PUBLIC_VAPI_ASSISTANT_ID=
# Optional web-call tuning (defaults shown):
NEXT_PUBLIC_VAPI_WEB_VOICE_ID=alloy
NEXT_PUBLIC_VAPI_WEB_VOICE_MODEL=tts-1
NEXT_PUBLIC_VAPI_WEB_TRANSCRIBER_MODEL_EN=flux-general-en
NEXT_PUBLIC_VAPI_WEB_TRANSCRIBER_MODEL_MULTI=flux-general-multi
NEXT_PUBLIC_VAPI_WEB_EOT_TIMEOUT_MS=5000
NEXT_PUBLIC_VAPI_WEB_EOT_THRESHOLD=0.7
